MYSQL_ROOT_PASSWORD=replace-with-a-long-random-root-password
MYSQL_APP_USERNAME=memesee_app
MYSQL_APP_PASSWORD=replace-with-a-long-random-app-password
MYSQL_HOST_PORT=3307

REDIS_PASSWORD=replace-with-a-long-random-redis-password
REDIS_HOST_PORT=6379

MINIO_ROOT_USER=replace-with-a-minio-admin-user
MINIO_ROOT_PASSWORD=replace-with-a-long-random-minio-password
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

MEILI_MASTER_KEY=replace-with-a-long-random-meilisearch-key
MEILI_HOST_PORT=7700

APP_SECURITY_JWT_SECRET=replace-with-a-long-random-shared-jwt-secret-at-least-32-chars
APP_SECURITY_INTERNAL_SERVICE_TOKEN=replace-with-a-long-random-internal-service-token

USER_DB_URL=jdbc:mysql://127.0.0.1:3307/memesee_user?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
USER_DB_USERNAME=memesee_app
USER_DB_PASSWORD=replace-with-the-same-value-as-MYSQL_APP_PASSWORD

CONTENT_DB_URL=jdbc:mysql://127.0.0.1:3307/memesee_content?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
CONTENT_DB_USERNAME=memesee_app
CONTENT_DB_PASSWORD=replace-with-the-same-value-as-MYSQL_APP_PASSWORD
MEMESEE_REDIS_HOST=127.0.0.1
MEMESEE_REDIS_PORT=6379
MEMESEE_REDIS_PASSWORD=replace-with-the-same-value-as-REDIS_PASSWORD
USER_SERVICE_URL=http://127.0.0.1:8081
CONTENT_SEARCH_MEILISEARCH_URL=http://127.0.0.1:7700
CONTENT_SEARCH_MEILISEARCH_API_KEY=replace-with-the-same-value-as-MEILI_MASTER_KEY
CONTENT_MEDIA_MINIO_ENDPOINT=http://127.0.0.1:9000
CONTENT_MEDIA_MINIO_ACCESS_KEY=replace-with-the-same-value-as-MINIO_ROOT_USER
CONTENT_MEDIA_MINIO_SECRET_KEY=replace-with-the-same-value-as-MINIO_ROOT_PASSWORD
